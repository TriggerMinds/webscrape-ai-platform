# =============================================================================
# WebScrape AI Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values before running docker compose.
#   cp .env.example .env
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
DB_USER=n8n
DB_PASSWORD=change-me-to-a-secure-password
DB_NAME=n8n
DB_PORT=5432

# --- n8n ---------------------------------------------------------------------
N8N_PORT=5678
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=change-me-to-a-random-32-char-string

# --- Crawlee API -------------------------------------------------------------
CRAWLEE_PORT=3001
PROXY_URL=socks5://127.0.0.1:1080

# --- Redis & Queue -----------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
MAX_CONCURRENCY=3

# --- CORS (comma-separated origins, * for all) --------------------------------
CORS_ORIGIN=*
